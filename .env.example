# Configuração de E-mail - Resend API
#
# Para obter sua chave de API do Resend:
# 1. Acesse https://resend.com/
# 2. Crie uma conta gratuita (100 emails/dia incluídos)
# 3. Vá em "API Keys" no dashboard
# 4. Clique em "Create API Key"
# 5. Copie a chave gerada
#
# IMPORTANTE: Esta chave deve ser configurada como variável de ambiente no Vercel:
# - Acesse seu projeto no Vercel Dashboard
# - Vá em Settings > Environment Variables
# - Adicione: RESEND_API_KEY com o valor da sua chave
# - Faça redeploy do projeto para aplicar as mudanças

RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx
